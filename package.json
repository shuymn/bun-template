{
  "name": "bun-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "lefthook install",
    "lint": "bunx biome lint .",
    "lint:fix": "bunx biome lint --fix .",
    "fmt:fix": "bunx biome format --write .",
    "fmt:check": "bunx biome format .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "check:fast": "bun run fmt:check && bun run lint && bun run typecheck",
    "check": "bun run check:fast && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.12",
    "lefthook": "2.1.6",
    "typescript": "6.0.3"
  }
}
